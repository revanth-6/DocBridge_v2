# ============================================================
# DocBridge Root Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ---------- PostgreSQL ----------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=docbridge_db
DB_USER=docbridge_user
DB_PASSWORD=DocBridge@2024Secure
DB_SSL=false

# ---------- JWT ----------
JWT_ACCESS_SECRET=replace_with_strong_secret_min_32_chars_access
JWT_REFRESH_SECRET=replace_with_strong_secret_min_32_chars_refresh
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ---------- Azure OpenAI ----------
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_KEY=your_azure_openai_key
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# ---------- Service Ports ----------
GATEWAY_PORT=3000
AUTH_SERVICE_PORT=3001
CONSULTATION_SERVICE_PORT=3002
PRESCRIPTION_SERVICE_PORT=3003
REMINDER_SERVICE_PORT=3004
LABREPORT_SERVICE_PORT=3005
SYMPTOM_SERVICE_PORT=3006
AI_COMPANION_SERVICE_PORT=3007
HEALTH_SUMMARY_SERVICE_PORT=3008
FAMILY_SERVICE_PORT=3009

# ---------- General ----------
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
LOG_LEVEL=debug
